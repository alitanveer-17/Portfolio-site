<script>
        // Smooth cursor animation interaction
        document.addEventListener('mousemove', (e) => {
            // Subtle parallax or glow effect could be added here if needed
        });

        // Intersection Observer for highlighting nav links
        const sections = document.querySelectorAll('section');
        const navLinks = document.querySelectorAll('nav a[href^="#"]');

        window.addEventListener('scroll', () => {
            let current = '';
            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.clientHeight;
                if (pageYOffset >= (sectionTop - 150)) {
                    current = section.getAttribute('id');
                }
            });

            navLinks.forEach(link => {
                link.classList.remove('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'pb-1');
                link.classList.add('text-on-surface-variant');
                if (link.getAttribute('href').includes(current)) {
                    link.classList.remove('text-on-surface-variant');
                    link.classList.add('text-primary', 'font-bold', 'border-b-2', 'border-primary', 'pb-1');
                }
            });
        });
    </script>
